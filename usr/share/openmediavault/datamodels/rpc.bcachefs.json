[
  {
    "type": "rpc",
    "id": "rpc.bcachefs.createfilesystem",
    "params": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string",
          "required": false
        },
        "compression": {
          "type": "string",
          "enum": ["none", "lz4", "gzip", "zstd"],
          "required": false
        },
        "replicas": {
          "type": "number",
          "minimum": 1,
          "maximum": 10,
          "required": false
        },
        "devicefiles": {
          "type": "string",
          "required": true
        }
      }
    }
  }
]
