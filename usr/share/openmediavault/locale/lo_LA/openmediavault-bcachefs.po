msgstr "ລາຍວັນ"

msgid "Data Integrity"
msgstr "ຄວາມຖືກຕ້ອງສົມບູນຂອງຂໍ້ມູນ"

msgid "Day of month"
msgstr "ມື້ຂອງເດືອນ"

msgid "Day of week"
msgstr "ມື້ຂອງອາທິດ"

msgid "December"
msgstr "ທັນວາ"

msgid "Devices"
msgstr "ອຸປະກອນ"

msgid "Disable COW"
msgstr "ປິດການໃຊ້ງານ COW"

msgid "Disable auto-unlock"
msgstr "ປິດການປົດລັອກອັດຕະໂນມັດ"

msgid ""
"Do you really want to disable auto-unlock? The key file will be deleted and "
"the filesystem will require a passphrase at next boot."
msgstr ""
"ທ່ານຕ້ອງການປິດການປົດລັອກອັດຕະໂນມັດແທ້ຫຼືບໍ່? ໄຟລ໌ກຸນແຈຈະຖືກລຶບ ແລະ "
"ລະບົບໄຟລ໌ຈະຕ້ອງມີລະຫັດຜ່ານໃນການບູດເຄື່ອງຄັ້ງຕໍ່ໄປ."

msgid "Edit"
msgstr "ແກ້ໄຂ"

msgid "Enable Auto-unlock"
msgstr "ເປີດການປົດລັອກອັດຕະໂນມັດ"

msgid "Enable auto-unlock"
msgstr "ເປີດການປົດລັອກອັດຕະໂນມັດ"

msgid "Enable device label groups"
msgstr ""

msgid ""
"Enable whole-filesystem encryption (chacha20/poly1305). Not available when "
"NoCOW is enabled."
msgstr ""
"ເປີດການເຂົ້າລະຫັດທັງໝົດຂອງລະບົບໄຟລ໌ (chacha20/poly1305). "
"ບໍ່ສາມາດໃຊ້ໄດ້ເມື່ອເປີດໃຊ້ NoCOW."

msgid "Enabled"
msgstr "ເປີດໃຊ້ງານ"

msgid "Encrypted"
msgstr "ເຂົ້າລະຫັດແລ້ວ"

msgid "Encryption"
msgstr "ການເຂົ້າລະຫັດ"

