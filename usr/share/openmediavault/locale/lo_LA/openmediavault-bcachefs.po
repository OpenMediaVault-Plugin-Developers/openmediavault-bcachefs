msgid ""
"Save the passphrase to a root-only key file so the filesystem unlocks "
"automatically at boot. The key is stored in /etc/bcachefs/keys/."
msgstr ""
"ບັນທຶກລະຫັດຜ່ານໄວ້ໃນໄຟລ໌ກຸນແຈທີ່ອ່ານໄດ້ສະເພາະ root "
"ເພື່ອໃຫ້ລະບົບໄຟລ໌ປົດລັອກອັດຕະໂນມັດຕອນບູດ. ກຸນແຈຈະຖືກເກັບໄວ້ໃນ "
"/etc/bcachefs/keys/."

msgid "Schedule"
msgstr "ຕາຕະລາງ"

msgid "Scheduling"
msgstr "ການຕັ້ງຕາຕະລາງ"

msgid "Scrub Jobs"
msgstr "ວຽກກວດສອບຂໍ້ມູນ (Scrub)"

msgid "Scrub started."
msgstr "ເລີ່ມການກວດສອບຂໍ້ມູນແລ້ວ."

msgid "Select devices ..."
msgstr "ເລືອກອຸປະກອນ ..."

msgid "Select the devices that will be used to create the file system."
msgstr "ເລືອກອຸປະກອນທີ່ຈະໃຊ້ໃນການສ້າງລະບົບໄຟລ໌."

msgid "Send email on error only"
msgstr "ສົ່ງອີເມລ໌ເມື່ອເກີດຂໍ້ຜິດພາດເທົ່ານັ້ນ"

msgid "Send output via email"
msgstr "ສົ່ງຜົນການເຮັດວຽກຜ່ານອີເມລ໌"

msgid "Send the command output via email on completion."
msgstr "ສົ່ງຜົນການເຮັດວຽກຂອງຄຳສັ່ງຜ່ານອີເມລ໌ເມື່ອສຳເລັດ."

msgid "September"
msgstr "ກັນຍາ"

msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

msgid "Snapshot"
msgstr "ສະນັບຊອດ"

msgid "Snapshot Jobs"
msgstr "ວຽກສະນັບຊອດ"

msgid "Snapshot prefix"
msgstr "ຄຳນຳໜ້າສະນັບຊອດ"

msgid ""
"Snapshots will be named <prefix>-YYYYMMDD-HHMMSS and stored in "
"<mountpoint>/.snapshots/<subvolume>/."
msgstr ""
"ສະນັບຊອດຈະຖືກຕັ້ງຊື່ເປັນ <prefix>-YYYYMMDD-HHMMSS ແລະ ເກັບໄວ້ໃນ "
"<mountpoint>/.snapshots/<subvolume>/."

msgid "Starting scrub ..."
msgstr "ກຳລັງເລີ່ມການກວດສອບຂໍ້ມູນ ..."

msgid "Subvolume"
msgstr "ຊັບວໍລຸມ"

msgid "Subvolumes"
msgstr "ຊັບວໍລຸມ"

msgid "Sunday"
msgstr "ວັນອາທິດ"

msgid "The field should only contain * or a comma separated list of values."
msgstr "ຊ່ອງນີ້ຄວນມີພຽງເຄື່ອງໝາຍ * ຫຼື ລາຍການຄ່າທີ່ຂັ້ນດ້ວຍຈຸດ."

msgid ""
"The filesystem or subvolume under which the new subvolume will be created."
msgstr "ລະບົບໄຟລ໌ ຫຼື ຊັບວໍລຸມ ທີ່ຈະໃຊ້ເປັນບ່ອນສ້າງຊັບວໍລຸມໃໝ່."

msgid "The name must not contain a slash."
msgstr "ຊື່ຕ້ອງບໍ່ມີເຄື່ອງໝາຍ slash (/)."

msgid "The name of the new subvolume."
msgstr "ຊື່ຂອງຊັບວໍລຸມໃໝ່."

msgid ""
"The number of devices must be at least equal to the number of replicas."
msgstr "ຈຳນວນອຸປະກອນຕ້ອງມີຢ່າງໜ້ອຍເທົ່າກັບຈຳນວນຊຸດສຳເນົາ (replicas)."

msgid ""
"The passphrase will be stored in /etc/bcachefs/keys/ readable only by root. "
"It is used to automatically unlock this filesystem at boot."
msgstr ""
"ລະຫັດຜ່ານຈະຖືກເກັບໄວ້ໃນ /etc/bcachefs/keys/ ເຊິ່ງອ່ານໄດ້ສະເພາະ root "
"ເທົ່ານັ້ນ. ມັນຖືກໃຊ້ເພື່ອປົດລັອກລະບົບໄຟລ໌ນີ້ໂດຍອັດຕະໂນມັດຕອນບູດ."

msgid "The passphrases do not match."
msgstr "ລະຫັດຜ່ານບໍ່ກົງກັນ."

msgid "Thursday"
msgstr "ວັນພະຫັດ"

msgid "Time of execution"
