msgid ""
"Write data in-place when possible. Improves performance for databases and VM"
" image storage. Implicitly disables checksums, compression, and encryption."
msgstr ""
"Waar mogelijk gegevens ter-plaatse schrijven. Verbetert de prestaties voor "
"databases en opslag van VM-images. Controlesommen, compressie en encryptie "
"zijn impliciet uitgeschakeld."

msgid "Yearly"
msgstr "Jaarlijks"

msgid ""
"bcachefs-kernel-dkms requires kernel 6.16 or newer. Your running kernel ({{ "
"kernelVersion }}) is not supported — the DKMS module will not be installed. "
"Upgrade your kernel and reboot to enable bcachefs."
msgstr ""

msgid "bcachefs-tools-release — stable builds (best for production use)"
msgstr ""
"bcachefs-tools-release — stabiele builds (beste voor betrouwbaar gebruik)"

msgid ""
"bcachefs-tools-snapshot — latest builds, updated often (best for testing and"
" development)"
msgstr ""
"bcachefs-tools-snapshot — jongste builds, vaak updates (beste voor testen en"
" ontwikkeling)"

