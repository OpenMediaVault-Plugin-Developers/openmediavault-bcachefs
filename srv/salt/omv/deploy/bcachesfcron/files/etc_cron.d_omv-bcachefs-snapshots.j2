# Managed by openmediavault-bcachefs plugin. Do not edit manually.
{%- set separator = ' ' -%}
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
# m h dom mon dow user    command
{%- for job in jobs | selectattr('enable') %}
{% if job.execution == "exactly" -%}
{% if job.everynminute | to_bool %}*/{{ job.minute }}{% else %}{{ job.minute }}{% endif -%}
{{ separator }}{% if job.everynhour | to_bool %}*/{{ job.hour }}{% else %}{{ job.hour }}{% endif -%}
{{ separator }}{% if job.everyndayofmonth | to_bool %}*/{{ job.dayofmonth }}{% else %}{{ job.dayofmonth }}{% endif -%}
{{ separator }}{{ job.month }}{{ separator }}{{ job.dayofweek }}
{%- else -%}
@{{ job.execution }}
{%- endif -%}
{{ separator }}root{{ separator }}/usr/sbin/omv-bcachefs-snapshot {{ job.subvolume | quote }} {{ job.prefix | quote }} {{ job.retention }}
{%- if (job.retentionunit | default('count')) != 'count' %} -u {{ job.retentionunit }}{% endif -%}
{%- if job.readonly | default(false) | to_bool %} -r{% endif -%}
{%- if job.sendemail | to_bool %} -e {{ 'onerror' if job.emailonerror | to_bool else 'always' }}{% if job.comment | length > 0 %} -c "{{ job.comment | replace('\n', ' ') }}"{% endif %}{% endif -%}
{{ separator }}>/dev/null 2>&1
{%- endfor %}
